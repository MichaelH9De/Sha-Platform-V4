# Prototype deployment: set only this value in Vercel.
DEMO_MODE="true"

# Enterprise deployment: set DEMO_MODE="false" and configure the values below.
# PostgreSQL is used in every enterprise environment to prevent development/production drift.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Microsoft Entra ID OpenID Connect. Generate AUTH_SECRET with a cryptographic password manager.
AUTH_SECRET="replace-with-at-least-32-random-bytes"
AUTH_TRUST_HOST="true"
AUTH_MICROSOFT_ENTRA_ID_ID="application-client-id"
AUTH_MICROSOFT_ENTRA_ID_SECRET="application-client-secret"
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/TENANT_ID/v2.0"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# HMAC secret used to authenticate integration webhooks.
WEBHOOK_SECRET="replace-with-a-separate-long-random-secret"
